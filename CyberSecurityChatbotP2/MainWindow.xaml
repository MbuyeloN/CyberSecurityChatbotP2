<Window x:Class="CyberSecurityChatbotP2.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="clr-namespace:CyberSecurityChatbotP2" mc:Ignorable="d" Title="Cybersecurity Awareness Chatbot" Height="650" Width="1000" WindowStartupLocation="CenterScreen" Background="#0F172A">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- HEADER -->
        <Border Background="#1E293B" CornerRadius="18" Padding="20" Margin="0,0,0,15" BorderBrush="#38BDF8" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="🛡 CYBERSECURITY AWARENESS CHATBOT" FontSize="30" FontWeight="Bold" Foreground="#F8FAFC" HorizontalAlignment="Center"/>
                <TextBlock Text="Helping you stay informed, protected, and safe online" FontSize="15" Foreground="#CBD5E1" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
        <!-- CHAT AREA -->
        <Border Grid.Row="1" Background="#111827" CornerRadius="18" Padding="15" BorderBrush="#334155" BorderThickness="1">
            <TextBox x:Name="ChatDisplay" Background="#111827" Foreground="#E5E7EB" BorderThickness="0" FontSize="15" FontFamily="Consolas" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" VerticalScrollBarVisibility="Auto"/>
        </Border>
        <!-- INPUT AREA -->
        <Border Grid.Row="2" Background="#1E293B" CornerRadius="18" Padding="15" Margin="0,15,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="UserInput" Height="45" FontSize="15" Padding="12,0,12,0" VerticalContentAlignment="Center" Background="#F8FAFC" Foreground="#0F172A" BorderThickness="0"/>
                <Button x:Name="SendButton" Grid.Column="1" Content="Send" Height="45" Margin="12,0,0,0" FontSize="16" FontWeight="Bold" Background="#38BDF8" Foreground="#0F172A" BorderThickness="0" Click="SendButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>