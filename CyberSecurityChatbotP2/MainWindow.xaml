<Window x:Class="CyberSecurityChatbotP2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberSecurityChatbotP2"
        mc:Ignorable="d"
        Title="Cybersecurity Awareness Chatbot"
        Height="760"
        Width="1350"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="#1E293B"
                CornerRadius="18"
                Padding="20"
                Margin="0,0,0,15"
                BorderBrush="#38BDF8"
                BorderThickness="1">

            <StackPanel>
                <TextBlock Text="🛡 CYBERSECURITY AWARENESS CHATBOT"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#F8FAFC"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Part 3: Task Assistant, Reminders, Quiz, NLP and Activity Log"
                           FontSize="15"
                           Foreground="#CBD5E1"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="15"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- CHAT AREA -->
            <Border Grid.Column="0"
                    Background="#111827"
                    CornerRadius="18"
                    Padding="20"
                    BorderBrush="#334155"
                    BorderThickness="1">

                <Grid>
                    <StackPanel x:Name="WelcomePanel"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center">

                        <TextBlock Text="🛡"
                                   FontSize="70"
                                   HorizontalAlignment="Center"
                                   Foreground="#38BDF8"/>

                        <TextBlock Text="Welcome to your Cybersecurity Assistant"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#F8FAFC"
                                   HorizontalAlignment="Center"
                                   Margin="0,10,0,0"/>

                        <TextBlock Text="Ask about passwords, phishing, scams, privacy, malware, or 2FA."
                                   FontSize="15"
                                   Foreground="#CBD5E1"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0"/>

                        <TextBlock Text="Type your name below to begin."
                                   FontSize="14"
                                   Foreground="#38BDF8"
                                   HorizontalAlignment="Center"
                                   Margin="0,12,0,0"/>
                    </StackPanel>

                    <TextBox x:Name="ChatDisplay"
                             Background="Transparent"
                             Foreground="#E5E7EB"
                             BorderThickness="0"
                             FontSize="15"
                             FontFamily="Consolas"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"/>
                </Grid>
            </Border>

            <!-- TASK ASSISTANT PANEL -->
            <Border Grid.Column="2"
                    Background="#1E293B"
                    CornerRadius="18"
                    Padding="18"
                    BorderBrush="#38BDF8"
                    BorderThickness="1">

                <StackPanel>
                    <TextBlock Text="📋 Task Assistant"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#F8FAFC"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Manage cybersecurity tasks and reminders"
                               FontSize="13"
                               Foreground="#CBD5E1"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,20"/>

                    <TextBlock Text="Task Title"
                               Foreground="#F8FAFC"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="TaskTitleInput"
                             Height="28"
                             Margin="0,5,0,12"
                             Padding="8,0,8,0"
                             VerticalContentAlignment="Center"
                             Background="#F8FAFC"
                             Foreground="#0F172A"
                             BorderThickness="0"/>

                    <TextBlock Text="Task Description"
                               Foreground="#F8FAFC"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="TaskDescriptionInput"
                             Height="28"
                             Margin="0,5,0,12"
                             Padding="8"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             Background="#F8FAFC"
                             Foreground="#0F172A"
                             BorderThickness="0"/>

                    <TextBlock Text="Reminder Date or Timeframe"
                               Foreground="#F8FAFC"
                               FontWeight="SemiBold"/>

                    <TextBox x:Name="TaskReminderInput"
                             Height="28"
                             Margin="0,5,0,15"
                             Padding="8,0,8,0"
                             VerticalContentAlignment="Center"
                             Background="#F8FAFC"
                             Foreground="#0F172A"
                             BorderThickness="0"
                             ToolTip="Example: Tomorrow, In 3 days, 2026-06-30"/>

                    <Button Content="Add Task"
                            Height="30"
                            Background="#38BDF8"
                            Foreground="#0F172A"
                            FontWeight="Bold"
                            BorderThickness="0"
                            Click="AddTaskButton_Click"/>

                    <TextBlock Text="Saved Tasks"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#F8FAFC"
                               Margin="0,22,0,8"/>

                    <ListBox x:Name="TaskListBox"
                             Height="40"
                             Background="#111827"
                             Foreground="#E5E7EB"
                             BorderBrush="#334155"
                             BorderThickness="1"/>

                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Content="Mark Complete"
                                Height="36"
                                Background="#22C55E"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Click="CompleteTaskButton_Click"/>

                        <Button Grid.Column="2"
                                Content="Delete"
                                Height="36"
                                Background="#EF4444"
                                Foreground="White"
                                FontWeight="Bold"
                                BorderThickness="0"
                                Click="DeleteTaskButton_Click"/>
                    </Grid>

                    <TextBlock Text="Part 3 task assistant feature"
                               FontSize="12"
                               Foreground="#94A3B8"
                               HorizontalAlignment="Center"
                               Margin="0,15,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- INPUT AREA -->
        <Border Grid.Row="2"
                Background="#1E293B"
                CornerRadius="18"
                Padding="15"
                Margin="0,15,0,0">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="UserInput"
                         Height="45"
                         FontSize="15"
                         Padding="12,0,12,0"
                         VerticalContentAlignment="Center"
                         Background="#F8FAFC"
                         Foreground="#0F172A"
                         BorderThickness="0"
                         KeyDown="UserInput_KeyDown"/>

                <Button x:Name="SendButton"
                        Grid.Column="1"
                        Content="Send"
                        Height="45"
                        Margin="12,0,0,0"
                        FontSize="16"
                        FontWeight="Bold"
                        Background="#38BDF8"
                        Foreground="#0F172A"
                        BorderThickness="0"
                        Click="SendButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>