<Window x:Class="CyberSecurityChatbotP2.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="clr-namespace:CyberSecurityChatbotP2" mc:Ignorable="d" Title="Cybersecurity Awareness Chatbot" Height="600" Width="950" WindowStartupLocation="CenterScreen" Background="#101820">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- HEADER -->
        <Border Background="#00ADB5" CornerRadius="10" Padding="15" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="CYBERSECURITY AWARENESS CHATBOT" FontSize="26" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Stay Smart. Stay Safe Online." FontSize="16" Foreground="White" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
        <!-- CHAT AREA -->
        <Border Grid.Row="1" Background="#1B262C" CornerRadius="10" Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBox x:Name="ChatDisplay" Background="#1B262C" Foreground="White" BorderThickness="0" FontSize="15" FontFamily="Consolas" TextWrapping="Wrap" AcceptsReturn="True" IsReadOnly="True" VerticalScrollBarVisibility="Auto"/>
            </ScrollViewer>
        </Border>
        <!-- INPUT AREA -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,0">
            <TextBox x:Name="UserInput" Width="700" Height="40" FontSize="15" Margin="0,0,10,0" VerticalContentAlignment="Center" Background="White" Foreground="Black"/>
            <Button x:Name="SendButton" Content="Send" Width="200" Height="40" FontSize="16" FontWeight="Bold" Background="#00ADB5" Foreground="White" Click="SendButton_Click"/>
        </StackPanel>
    </Grid>
</Window>